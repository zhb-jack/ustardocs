time="2026-03-15T16:37:14+08:00" level=info msg="/workspace/ustarpay-backend-go/internal/infrastructure/database/wallet/repository/cold_wallet.go:155\n[4.751ms] [rows:0] SELECT \n\t\t\tw.id,\n\t\t\tw.tenant_id,\n\t\t\tw.name,\n\t\t\tw.description,\n\t\t\tw.address,\n\t\t\tw.chain_codes,\n\t\t\tw.symbols,\n\t\t\tw.status,\n\t\t\tw.created_at,\n\t\t\tw.updated_at,\n\t\t\tCASE \n\t\t\t\tWHEN COUNT(sa.chain_code) FILTER (WHERE sa.chain_code IS NOT NULL AND sa.chain_code != 'unknown') > 0 \n\t\t\t\tTHEN jsonb_object_agg(sa.chain_code, sa.symbols_json) FILTER (WHERE sa.chain_code IS NOT NULL AND sa.chain_code != 'unknown')\n\t\t\t\tELSE NULL\n\t\t\tEND AS balance_by_chain\n\t\t FROM tenant_cold_wallets AS w LEFT JOIN (SELECT \n\t\t\tw.id AS wallet_id,\n\t\t\tCOALESCE(NULLIF(b.chain_code, ''), 'unknown') AS chain_code,\n\t\t\tjsonb_object_agg(\n\t\t\t\tCOALESCE(NULLIF(b.symbol, ''), 'unknown'),\n\t\t\t\tjsonb_build_object(\n\t\t\t\t\t'balance', b.balance,\n\t\t\t\t\t'lastBlockHeight', b.last_block_height\n\t\t\t\t)\n\t\t\t) AS symbols_json\n\t\t FROM tenant_cold_wallets AS w LEFT JOIN tenant_cold_wallet_balances b\n\t\t\tON b.address = w.address\n\t\t\tAND b.tenant_id = w.tenant_id\n\t\t\tAND b.deleted_at IS NULL WHERE w.tenant_id = '7b49a938-0f04-4a21-987d-627417816f49' AND w.deleted_at IS NULL GROUP BY w.id, b.chain_code) AS sa ON sa.wallet_id = w.id WHERE w.tenant_id = '7b49a938-0f04-4a21-987d-627417816f49' AND w.deleted_at IS NULL GROUP BY \"w\".\"id\" LIMIT 10"
